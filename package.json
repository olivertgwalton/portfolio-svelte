{
	"name": "portfolio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"start": "bun ./build/index.js",
		"dev": "bun x --bun vite dev",
		"build": "bun x --bun vite build",
		"preview": "bun x --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "bun biome check . && bun eslint .",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:perf": "playwright test --project=performance",
		"test:e2e:update-snapshots": "playwright test --update-snapshots",
		"format": "bun biome format --write .",
		"build:wasm": "mkdir -p static/wasm && cd rust-grid && RUSTFLAGS='-C target-feature=+simd128' wasm-pack build --target web --out-dir ../src/lib/wasm && mv ../src/lib/wasm/rust_grid_bg.wasm ../static/wasm/"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@biomejs/biome": "^2.5.2",
		"@eslint/config-helpers": "^0.6.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/enhanced-img": "^0.11.0",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/bun": "^1.3.14",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"katex": "^0.17.0",
		"lighthouse": "^13.4.0",
		"mdast-util-to-string": "^4.0.0",
		"mdsvex": "^0.12.7",
		"playwright-lighthouse": "^4.0.0",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-katex": "7.0.1",
		"rehype-slug": "^6.0.0",
		"remark-math": "6.0.0",
		"sharp": "^0.35.3",
		"shiki": "^4.3.1",
		"svelte": "^5.56.4",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"unist-util-visit": "^5.1.0",
		"vite": "^8.1.3"
	},
	"dependencies": {
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource-variable/manrope": "^5.2.8",
		"@fontsource-variable/space-grotesk": "^5.2.10",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@takumi-rs/core": "^1.8.7",
		"@takumi-rs/helpers": "^1.8.7",
		"phosphor-svelte": "^3.1.0"
	}
}
